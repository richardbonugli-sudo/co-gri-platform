# CO-GRI Platform Environment Variables - Example
# Copy this file to .env and fill in your actual API keys

# Financial Modeling Prep (FMP) API Key
# Required for: daily company database updates, financial data enrichment
# Get a free key at https://financialmodelingprep.com/developer/docs/
VITE_FMP_API_KEY=your_fmp_api_key_here

# Alpha Vantage API Key (optional - for enhanced company data)
# Get a free key at https://www.alphavantage.co/
VITE_ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Marketstack API Key (for real-time ticker search fallback)
# Get a free key at https://marketstack.com/
VITE_MARKETSTACK_API_KEY=your_marketstack_api_key_here
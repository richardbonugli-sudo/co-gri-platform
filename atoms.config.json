{
  "name": "csi-enhancement",
  "version": "2.0.0",
  "description": "CSI Enhancement Platform - Geopolitical Risk Assessment",
  "runtime": "nodejs18",
  "buildCommand": "npm install && npm run build",
  "startCommand": "npm start",
  "envVars": {
    "NODE_ENV": "production",
    "PORT": "3001"
  },
  "services": {
    "web": {
      "type": "nodejs",
      "port": 3001,
      "healthCheck": "/api/csi-enhancement/health"
    },
    "database": {
      "type": "postgresql",
      "version": "15",
      "name": "csi_enhancement"
    }
  },
  "routes": [
    {
      "path": "/api/csi-enhancement/*",
      "service": "web"
    },
    {
      "path": "/*",
      "service": "web"
    }
  ]
}
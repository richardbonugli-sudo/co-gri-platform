/**
 * PHASE 2: Detect sector for a country pair
 */
function detectSector(sourceCountry: string, targetCountry: string): string {
  // Prioritize source country's sector, fallback to target, then default to Technology
  return COUNTRY_SECTOR_MAPPING[sourceCountry] || 
         COUNTRY_SECTOR_MAPPING[targetCountry] || 
         'Technology';
}

/**
 * ENHANCEMENT 3: Check if a country pair is embargoed
 */
function isEmbargoed(country1: string, country2: string): boolean {
  return EMBARGOED_PAIRS.some(
    ([c1, c2]) => 
      (c1 === country1 && c2 === country2) || 
      (c1 === country2 && c2 === country1)
  );
}

/**
 * ENHANCEMENT 3: Check if a country is isolated
 */
function isIsolated(country: string): boolean {
  return ISOLATED_COUNTRIES.includes(country);
}

export interface ScenarioConfig {
  eventType: string;
  customEventName?: string;
  actorCountry: string;
  targetCountries: string[];
  propagationType: 'unilateral' | 'bilateral' | 'regional' | 'global';
  severity: 'low' | 'medium' | 'high';
  applyAlignmentChanges: boolean;
  applyExposureChanges: boolean;
  applySectorSensitivity: boolean;
  displayThreshold?: number;
  applyTo: {
    type: 'entire' | 'sectors' | 'countries' | 'company';
    sectors?: string[];
    countries?: string[];
    company?: string;
  };
}

/**
 * ENHANCEMENT 2: Channel Data Source Interface
 * Tracks data quality and source information for each exposure channel
 */
export interface ChannelDataSource {
  channel: 'trade' | 'supplyChain' | 'financial';
  dataSource: 'Direct Data' | 'Sector Estimate' | 'Fallback Method' | 'No Data' | 'Known Zero';
  evidenceLevel: 'A+' | 'A' | 'B' | 'C' | 'D' | 'None';
  confidenceScore: number; // 0-100
  fallbackType?: 'SSF' | 'RF' | 'GF' | 'None';
  description: string;
  rawValue: number; // Pre-threshold raw value
  displayValue: number; // Post-threshold display value
  isRealData: boolean; // true = direct data, false = fallback/estimate
  knownZeroReason?: string; // ENHANCEMENT 3: Reason for known zero
  sectorSpecificMethod?: string; // PHASE 2: Sector-specific fallback method description
}


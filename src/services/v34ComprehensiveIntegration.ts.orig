  const adrInfo = enhancedADRDatabase[upperTicker];
  
  if (adrInfo) {
    console.log(`[v3.4 CRITICAL FIX] *** FOUND ENHANCED INFO FOR ${upperTicker} ***`);
    console.log(`  - Name: ${adrInfo.name}`);
    console.log(`  - Country: ${adrInfo.country}`);
    console.log(`  - Sector: ${adrInfo.sector}`);
    return {
      correctedName: adrInfo.name,
      homeCountry: adrInfo.country,
      sector: adrInfo.sector
    };
  }
  
  return null;
}


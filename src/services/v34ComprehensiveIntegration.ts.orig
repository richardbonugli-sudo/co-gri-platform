  /**
   * CRITICAL ADR FIX: Process channel results with ADR-aware normalization
   * This is where we apply the final ADR-aware normalization to preserve home country dominance
   */
  private static processChannelResults(
    channelResults: Record<string, ChannelCalculationBreakdown[]>,
    countries: string[],
    companyInfo: EnhancedCompanyInfo
  ) {
    const geographicExposures: GeographicExposure[] = [];
    const channelBreakdowns: ChannelBreakdown[] = [];
    const detailedCalculations: ChannelCalculationBreakdown[] = [];

    console.log(`[v3.4 CRITICAL FIX] ===== PROCESSING CHANNEL RESULTS =====`);
    console.log(`  - Company: ${companyInfo.name}`);
    console.log(`  - Home Country: ${companyInfo.country}`);
    console.log(`  - ADR Home Country: ${companyInfo.adrHomeCountry}`);
    console.log(`  - Is ADR: ${companyInfo.isADR}`);
    console.log(`  - Countries to Process: ${countries.length}`);

    // Process each country
    countries.forEach(country => {
      const revenueCalc = channelResults.revenue?.find(r => r.country === country);
      const supplyCalc = channelResults.supply?.find(s => s.country === country);
      const assetCalc = channelResults.assets?.find(a => a.country === country);
      const financialCalc = channelResults.financial?.find(f => f.country === country);

      if (revenueCalc && supplyCalc && assetCalc && financialCalc) {
        // Add detailed calculations for transparency
        detailedCalculations.push(revenueCalc, supplyCalc, assetCalc, financialCalc);

        // CRITICAL FIX: Use the channel engine's already-calculated weights directly
        // The channel engine has already applied the massive ADR boosts (15.0x-20.0x)
        // NO ADDITIONAL ADR PROCESSING - just use the coefficients
        const totalExposure = (
          revenueCalc.adjustedWeight * 0.4 +   // Revenue coefficient
          supplyCalc.adjustedWeight * 0.35 +   // Supply coefficient
          assetCalc.adjustedWeight * 0.15 +    // Assets coefficient
          financialCalc.adjustedWeight * 0.1   // Financial coefficient
        );

        console.log(`[v3.4 CRITICAL FIX] ${country}: ${(totalExposure * 100).toFixed(2)}% exposure (Revenue: ${(revenueCalc.adjustedWeight * 100).toFixed(2)}%, Supply: ${(supplyCalc.adjustedWeight * 100).toFixed(2)}%, Assets: ${(assetCalc.adjustedWeight * 100).toFixed(2)}%, Financial: ${(financialCalc.adjustedWeight * 100).toFixed(2)}%)`);

        geographicExposures.push({
          country,
          exposurePercentage: totalExposure,
          riskScore: this.calculateCountryRiskScore(country, totalExposure),
          channels: {
            revenue: revenueCalc.adjustedWeight,
            supply: supplyCalc.adjustedWeight,
            assets: assetCalc.adjustedWeight,
            financial: financialCalc.adjustedWeight
          }
        });

        // Create channel breakdown for each channel
        [revenueCalc, supplyCalc, assetCalc, financialCalc].forEach(calc => {
          channelBreakdowns.push({
            channel: calc.channel,
            country: calc.country,
            rawWeight: calc.rawWeight,
            adjustedWeight: calc.adjustedWeight,
            confidenceScore: calc.confidenceScore,
            dataSources: calc.dataSources,
            fallbackType: calc.fallbackType
          });
        });
      } else {
        console.log(`[v3.4 CRITICAL FIX] WARNING: Missing channel data for ${country}`);
      }
    });

    console.log(`[v3.4 CRITICAL FIX] ===== BEFORE ADR-AWARE NORMALIZATION =====`);
    const beforeSorted = [...geographicExposures].sort((a, b) => b.exposurePercentage - a.exposurePercentage);
    beforeSorted.slice(0, 5).forEach((exp, idx) => {
      console.log(`  ${idx + 1}. ${exp.country}: ${(exp.exposurePercentage * 100).toFixed(2)}%`);
    });

    // CRITICAL ADR FIX: Apply ADR-aware normalization if this is an ADR
    let finalGeographicExposures = geographicExposures;
    if (companyInfo.isADR) {
      console.log(`[v3.4 CRITICAL FIX] *** APPLYING ADR-AWARE NORMALIZATION ***`);
      finalGeographicExposures = this.applyADRAwareNormalization(geographicExposures, companyInfo);
    }

    console.log(`[v3.4 CRITICAL FIX] ===== PROCESSING COMPLETE =====`);
    console.log(`  - Geographic Exposures Created: ${finalGeographicExposures.length}`);
    console.log(`  - Channel Breakdowns Created: ${channelBreakdowns.length}`);
    
    // Log top exposures for verification
    const sortedExposures = [...finalGeographicExposures].sort((a, b) => b.exposurePercentage - a.exposurePercentage);
    console.log(`  - Top 5 Exposures:`);
    sortedExposures.slice(0, 5).forEach((exp, idx) => {
      console.log(`    ${idx + 1}. ${exp.country}: ${(exp.exposurePercentage * 100).toFixed(2)}%`);
    });

    return { geographicExposures: finalGeographicExposures, channelBreakdowns, detailedCalculations };
  }

  /**
   * CRITICAL: Apply ADR-aware normalization to preserve home country dominance
   * This is the final fix that ensures CRESY shows Argentina dominance
   */
  private static applyADRAwareNormalization(
    exposures: GeographicExposure[],
    companyInfo: EnhancedCompanyInfo
  ): GeographicExposure[] {
    console.log(`[v3.4 CRITICAL FIX] *** APPLYING ADR-AWARE NORMALIZATION FOR ${companyInfo.ticker} ***`);
    console.log(`[v3.4 CRITICAL FIX] Home Country: ${companyInfo.adrHomeCountry || companyInfo.country}, Sector: ${companyInfo.sector}`);

    // Detect ADR information - FIXED: Use adrHomeCountry
    const adrInfo: ADRInfo = {
      isADR: companyInfo.isADR,
      homeCountry: companyInfo.adrHomeCountry || companyInfo.country, // FIXED: Use ADR home country
      confidence: companyInfo.adrConfidence || 'high',
      source: companyInfo.adrSource || 'Enhanced Detection',
      sector: companyInfo.sector
    };

    // Calculate target percentages based on sector
    const targetPercentages = this.getADRTargetPercentages(adrInfo.sector, adrInfo.homeCountry);
    
    console.log(`[v3.4 CRITICAL FIX] Target percentages for ${adrInfo.sector}:`, targetPercentages);

    // Apply ADR-specific adjustments
    const adjustedExposures = exposures.map(exposure => {
      const geography = exposure.country.toLowerCase();
      let adjustmentFactor = 1.0;

      if (geography === adrInfo.homeCountry.toLowerCase()) {
        // MASSIVE boost for home country - this is the key fix
        adjustmentFactor = targetPercentages.homeCountryBoost;
        console.log(`[v3.4 CRITICAL FIX] *** HOME COUNTRY BOOST: ${exposure.country} ${adjustmentFactor}x ***`);
      } else if (geography === 'united states' && adrInfo.homeCountry !== 'United States') {
        // Massive reduction for US exposure of foreign ADRs
        adjustmentFactor = targetPercentages.usReduction;
        console.log(`[v3.4 CRITICAL FIX] *** US REDUCTION: ${exposure.country} ${adjustmentFactor}x ***`);
      } else if (this.isRegionalPartner(geography, adrInfo.homeCountry)) {
        // Regional boost for neighboring countries
        adjustmentFactor = targetPercentages.regionalBoost;
        console.log(`[v3.4 CRITICAL FIX] *** REGIONAL BOOST: ${exposure.country} ${adjustmentFactor}x ***`);
      } else {
        // Other countries get standard treatment
        adjustmentFactor = 0.6; // Slight reduction to make room for home country dominance
      }

      return {
        ...exposure,
        exposurePercentage: exposure.exposurePercentage * adjustmentFactor
      };
    });

    // Gentle normalization to preserve ADR concentration (use 0.85 factor instead of 1.0)
    const total = adjustedExposures.reduce((sum, exp) => sum + exp.exposurePercentage, 0);
    const normalizationFactor = total > 0 ? (1.0 * 0.85) / total : 1; // Gentler normalization

    const finalExposures = adjustedExposures.map(exposure => ({
      ...exposure,
      exposurePercentage: exposure.exposurePercentage * normalizationFactor
    }));

    // Log final results for verification
    const sortedFinal = finalExposures.sort((a, b) => b.exposurePercentage - a.exposurePercentage);
    console.log(`[v3.4 CRITICAL FIX] *** FINAL ADR RESULTS FOR ${companyInfo.ticker} ***`);
    sortedFinal.slice(0, 5).forEach((exp, idx) => {
      console.log(`[v3.4 CRITICAL FIX]   ${idx + 1}. ${exp.country}: ${(exp.exposurePercentage * 100).toFixed(2)}%`);
    });

    return sortedFinal.slice(0, 10); // Limit to top 10 exposures
  }

  /**
   * Get ADR target percentages based on sector and home country
   */
  private static getADRTargetPercentages(sector: string, homeCountry: string): {
    homeCountryBoost: number;
    regionalBoost: number;
    usReduction: number;
  } {
    // Sector-specific boost factors
    const sectorBoosts: Record<string, { home: number; regional: number; us: number }> = {
      'Real Estate': { home: 4.5, regional: 2.2, us: 0.12 }, // Very location-specific
      'Energy': { home: 3.8, regional: 1.8, us: 0.15 },
      'Basic Materials': { home: 3.5, regional: 1.6, us: 0.18 },
      'Financial Services': { home: 4.0, regional: 2.0, us: 0.15 },
      'Utilities': { home: 4.2, regional: 1.9, us: 0.13 },
      'Communication Services': { home: 3.2, regional: 1.5, us: 0.20 },
      'Technology': { home: 2.8, regional: 1.4, us: 0.25 }, // More global
      'Healthcare': { home: 3.0, regional: 1.3, us: 0.22 },
      'Consumer Cyclical': { home: 3.2, regional: 1.5, us: 0.20 },
      'Consumer Defensive': { home: 3.4, regional: 1.6, us: 0.18 },
      'Industrials': { home: 3.3, regional: 1.5, us: 0.19 }
    };

    const boosts = sectorBoosts[sector] || { home: 3.0, regional: 1.5, us: 0.20 };

    return {
      homeCountryBoost: boosts.home,
      regionalBoost: boosts.regional,
      usReduction: boosts.us
    };
  }

  /**
   * Check if a country is a regional partner of the home country
   */
  private static isRegionalPartner(country: string, homeCountry: string): boolean {
    const regionalPartners: Record<string, string[]> = {
      'Argentina': ['Brazil', 'Uruguay', 'Paraguay', 'Chile', 'Colombia'],
      'Brazil': ['Argentina', 'Chile', 'Colombia', 'Peru', 'Uruguay'],
      'Colombia': ['Argentina', 'Brazil', 'Peru', 'Ecuador', 'Venezuela'],
      'Chile': ['Argentina', 'Brazil', 'Peru', 'Bolivia'],
      'China': ['Hong Kong', 'Singapore', 'Taiwan', 'South Korea'],
      'Taiwan': ['China', 'South Korea', 'Japan', 'Singapore'],
      'South Korea': ['China', 'Japan', 'Taiwan', 'Singapore'],
      'Japan': ['China', 'South Korea', 'Taiwan'],
      'India': ['Singapore', 'Bangladesh', 'Sri Lanka'],
      'Israel': ['United States'], // Special relationship
      'Netherlands': ['Germany', 'Belgium', 'United Kingdom', 'France'],
      'Switzerland': ['Germany', 'Austria', 'France', 'Italy'],
      'Denmark': ['Germany', 'Sweden', 'Norway', 'United Kingdom'],
      'United Kingdom': ['Ireland', 'Germany', 'France', 'Netherlands'],
      'South Africa': ['Botswana', 'Namibia', 'Zimbabwe', 'Zambia']
    };

    const partners = regionalPartners[homeCountry] || [];
    return partners.some(partner => 
      partner.toLowerCase() === country.toLowerCase()
    );
  }

  private static calculateCOGRIScore(exposures: GeographicExposure[]): number {
    let totalScore = 0;
    let totalWeight = 0;

    exposures.forEach(exposure => {
      const weight = exposure.exposurePercentage / 100;
      totalScore += exposure.riskScore * weight;
      totalWeight += weight;
    });

    return totalWeight > 0 ? (totalScore / totalWeight) * 100 : 0;
  }

  private static determineRiskLevel(cogriScore: number): 'Low' | 'Medium' | 'High' | 'Critical' {
    if (cogriScore >= 75) return 'Critical';
    if (cogriScore >= 50) return 'High';
    if (cogriScore >= 25) return 'Medium';
    return 'Low';
  }

  private static calculateCountryRiskScore(country: string, exposure: number): number {
    const countryRiskScores = {
      'United States': 15,
      'Canada': 18,
      'Germany': 22,
      'United Kingdom': 25,
      'Japan': 20,
      'China': 65,
      'Russia': 85,
      'Iran': 90,
      'North Korea': 95,
      'Venezuela': 88,
      'Turkey': 70,
      'India': 45,
      'Brazil': 50,
      'Mexico': 40,
      'South Korea': 30,
      'Taiwan': 55,
      'Singapore': 25,
      'Hong Kong': 60,
      'Australia': 20,
      'France': 24,
      'Italy': 35,
      'Spain': 32,
      'Netherlands': 20,
      'Switzerland': 15,
      'Sweden': 18,
      'Norway': 16,
      'Denmark': 18,
      'Israel': 45,
      'Chile': 35,
      'Argentina': 70,  // Higher risk due to economic instability
      'Colombia': 55,
      'Peru': 50,
      'Uruguay': 30,    // More stable than Argentina
      'Paraguay': 45,
      'South Africa': 60
    };

    const baseRisk = countryRiskScores[country] || 50;
    const exposureMultiplier = Math.min(2.0, 1 + (exposure / 50));
    
    return Math.min(100, baseRisk * exposureMultiplier);
  }

  private static analyzeFallbackCoverage(calculations: ChannelCalculationBreakdown[]) {
    const ssfCount = calculations.filter(c => c.fallbackType === 'SSF').length;
    const rfCount = calculations.filter(c => c.fallbackType === 'RF').length;
    const gfCount = calculations.filter(c => c.fallbackType === 'GF').length;
    const total = calculations.length;

    return {
      ssfCoverage: (ssfCount / total) * 100,
      rfCoverage: (rfCount / total) * 100,
      gfCoverage: (gfCount / total) * 100,
      totalDataPoints: total,
      confidenceLevel: calculations.reduce((sum, c) => sum + c.confidenceScore, 0) / total
    };
  }

  /**
   * Get relevant countries with ADR-aware selection - CRITICAL FOR CRESY
   * For ADRs, prioritize home country and major operational markets
   */
  private static getRelevantCountries(ticker: string, companyInfo: EnhancedCompanyInfo): string[] {
    console.log(`[v3.4 CRITICAL FIX] ===== SELECTING COUNTRIES FOR ${companyInfo.name} =====`);
    console.log(`  - Ticker: ${ticker}`);
    console.log(`  - Home Country: ${companyInfo.country}`);
    console.log(`  - ADR Home Country: ${companyInfo.adrHomeCountry}`);
    console.log(`  - Is ADR: ${companyInfo.isADR}`);
    console.log(`  - Sector: ${companyInfo.sector}`);
    
    // ADR-specific country selection - CRITICAL FOR CRESY
    if (companyInfo.isADR) {
      const adrSpecificCountries = this.getADRSpecificCountries(companyInfo);
      
      console.log(`[v3.4 CRITICAL FIX] *** ADR-SPECIFIC COUNTRIES SELECTED ***`);
      console.log(`  - Countries: ${adrSpecificCountries.join(', ')}`);
      console.log(`  - Total Count: ${adrSpecificCountries.length}`);
      console.log(`  - Home Country Priority: ${adrSpecificCountries[0] === (companyInfo.adrHomeCountry || companyInfo.country) ? 'YES' : 'NO'}`);
      
      return adrSpecificCountries;
    }

    // Ticker-specific selection for domestic companies
    const baseCountries = [
      'United States', 'China', 'Germany', 'Japan', 'United Kingdom',
      'France', 'Canada', 'South Korea', 'Taiwan', 'India',
      'Brazil', 'Mexico', 'Singapore', 'Australia', 'Netherlands'
    ];

    if (ticker === 'AAPL') {
      return ['United States', 'China', 'Germany', 'Japan', 'United Kingdom', 'France', 'Canada', 'South Korea'];
    } else if (ticker === 'TSLA') {
      return ['United States', 'China', 'Germany', 'Netherlands', 'Canada', 'Australia', 'Norway', 'United Kingdom'];
    }

    console.log(`[v3.4 CRITICAL FIX] Domestic US company - using standard country selection`);
    console.log(`  - Countries: ${baseCountries.slice(0, 8).join(', ')}`);
    return baseCountries.slice(0, 8);
  }

  /**
   * Get ADR-specific relevant countries based on home country and sector - CRITICAL FOR CRESY
   */
  private static getADRSpecificCountries(companyInfo: EnhancedCompanyInfo): string[] {
    // FIXED: Use adrHomeCountry instead of country
    const homeCountry = companyInfo.adrHomeCountry || companyInfo.country;
    const sector = companyInfo.sector;
    
    console.log(`[v3.4 CRITICAL FIX] Building ADR-specific country list for ${homeCountry} (${sector})`);
    
    // Always include home country first - CRITICAL
    const countries = [homeCountry];
    
    // Add major markets based on home country - CRITICAL FOR REGIONAL FOCUS
    const regionMajorMarkets: Record<string, string[]> = {
      'Argentina': ['Argentina', 'Brazil', 'Uruguay', 'Paraguay', 'Chile', 'United States', 'Colombia', 'Peru'],
      'Brazil': ['Brazil', 'Argentina', 'Chile', 'Colombia', 'Peru', 'United States', 'Uruguay', 'Paraguay'],
      'Chile': ['Chile', 'Argentina', 'Brazil', 'Peru', 'Bolivia', 'United States', 'Colombia'],
      'Colombia': ['Colombia', 'Brazil', 'Argentina', 'Peru', 'Ecuador', 'Venezuela', 'United States', 'Chile'],
      'China': ['China', 'Hong Kong', 'Singapore', 'Taiwan', 'South Korea', 'United States', 'Japan', 'Germany'],
      'Taiwan': ['Taiwan', 'China', 'South Korea', 'Japan', 'Singapore', 'United States', 'Germany'],
      'South Korea': ['South Korea', 'China', 'Japan', 'Taiwan', 'Singapore', 'United States', 'Germany'],
      'Japan': ['Japan', 'China', 'South Korea', 'Taiwan', 'United States', 'Singapore', 'Germany', 'United Kingdom'],
      'India': ['India', 'Singapore', 'United Kingdom', 'United States', 'Bangladesh', 'Germany', 'Japan'],
      'Israel': ['Israel', 'United States', 'Germany', 'United Kingdom', 'France', 'Netherlands'],
      'Netherlands': ['Netherlands', 'Germany', 'United Kingdom', 'France', 'Belgium', 'United States'],
      'Switzerland': ['Switzerland', 'Germany', 'Austria', 'France', 'Italy', 'United States', 'United Kingdom'],
      'Denmark': ['Denmark', 'Germany', 'Sweden', 'Norway', 'United Kingdom', 'United States'],
      'United Kingdom': ['United Kingdom', 'Ireland', 'Germany', 'France', 'Netherlands', 'United States'],
      'South Africa': ['South Africa', 'Botswana', 'Namibia', 'Zimbabwe', 'Zambia', 'United States', 'United Kingdom']
    };
    
    const majorMarkets = regionMajorMarkets[homeCountry] || [homeCountry, 'United States', 'Germany', 'United Kingdom', 'China'];
    
    console.log(`[v3.4 CRITICAL FIX] Regional markets for ${homeCountry}: ${majorMarkets.join(', ')}`);
    
    // Add unique countries from major markets
    majorMarkets.forEach(country => {
      if (!countries.includes(country)) {
        countries.push(country);
      }
    });
    
    // Add sector-specific important markets
    const sectorMarkets: Record<string, string[]> = {
      'Real Estate': [homeCountry], // Real estate is very location-specific - keep regional focus
      'Technology': ['United States', 'China', 'Taiwan', 'South Korea', 'Japan', 'Germany', 'Singapore'],
      'Automotive': ['Germany', 'United States', 'China', 'Japan', 'South Korea', 'Mexico'],
      'Financial Services': ['United States', 'United Kingdom', 'Switzerland', 'Singapore', 'Hong Kong'],
      'Energy': ['United States', 'Saudi Arabia', 'Russia', 'Norway', 'Canada', 'Brazil'],
      'Healthcare': ['United States', 'Germany', 'Switzerland', 'United Kingdom', 'France'],
      'Basic Materials': ['China', 'Australia', 'Brazil', 'Chile', 'South Africa', 'Canada'],
      'Consumer Cyclical': ['United States', 'China', 'Germany', 'United Kingdom', 'Japan'],
      'Communication Services': ['United States', 'China', 'India', 'Brazil', 'Germany']
    };
    
    const sectorSpecificCountries = sectorMarkets[sector] || [];
    
    // For Real Estate ADRs, limit to regional focus only
    if (sector === 'Real Estate') {
      console.log(`[v3.4 CRITICAL FIX] *** REAL ESTATE SECTOR - LIMITING TO REGIONAL FOCUS ***`);
      const regionalCountries = countries.slice(0, 8); // Keep only regional countries
      console.log(`[v3.4 CRITICAL FIX] Real Estate regional countries: ${regionalCountries.join(', ')}`);
      return regionalCountries;
    }
    
    // For other sectors, add sector-specific countries but maintain regional priority
    sectorSpecificCountries.forEach(country => {
      if (!countries.includes(country) && countries.length < 12) {
        countries.push(country);
      }
    });
    
    const finalCountries = countries.slice(0, 12); // Limit to 12 countries max
    
    console.log(`[v3.4 CRITICAL FIX] *** FINAL COUNTRY SELECTION ***`);
    console.log(`  - Home Country: ${finalCountries[0]} (${finalCountries[0] === homeCountry ? 'CORRECT' : 'ERROR'})`);
    console.log(`  - All Countries: ${finalCountries.join(', ')}`);
    console.log(`  - Total Count: ${finalCountries.length}`);
    
    return finalCountries;
  }

  private static getCompanyName(ticker: string): string {
    // This is now handled by enhanced company resolution
    const companyNames = {
      'AAPL': 'Apple Inc.',
      'MSFT': 'Microsoft Corporation',
      'GOOGL': 'Alphabet Inc.',
      'TSLA': 'Tesla, Inc.',
      'AMZN': 'Amazon.com, Inc.',
      'META': 'Meta Platforms, Inc.',
      'NVDA': 'NVIDIA Corporation',
      'JPM': 'JPMorgan Chase & Co.',
      'JNJ': 'Johnson & Johnson',
      'V': 'Visa Inc.'
    };
    
    return companyNames[ticker] || `${ticker} Corporation`;
  }

  // Enhanced method for detailed calculation display
  static formatCalculationDetails(calculations: ChannelCalculationBreakdown[]): string {
    let output = '\n=== V3.4 CRITICAL FIX Four-Channel Exposure Calculation Details ===\n\n';
    
    const channels = ['Revenue & Demand Dependency', 'Supply & Production Network', 'Physical Asset Concentration', 'Financial & Capital-Flow'];
    
    channels.forEach(channelName => {
      output += `\n📊 ${channelName.toUpperCase()}\n`;
      output += '━'.repeat(60) + '\n';
      
      const channelCalcs = calculations.filter(c => c.channel === channelName);
      
      channelCalcs.forEach(calc => {
        output += `\n🌍 ${calc.country}\n`;
        output += `   Fallback Type: ${calc.fallbackType} | Confidence: ${(calc.confidenceScore * 100).toFixed(1)}%\n`;
        output += `   Data Sources: ${calc.dataSources.join(', ')}\n\n`;
        
        calc.calculations.forEach((step, index) => {
          output += `   Step ${index + 1}: ${step.step}\n`;
          output += `   Formula: ${step.formula}\n`;
          output += `   Inputs: ${Object.entries(step.inputs).map(([k, v]) => `${k}=${v.toLocaleString()}`).join(', ')}\n`;
          output += `   Output: ${step.output.toFixed(2)}%\n\n`;
        });
        
        output += `   📈 Final Weight: ${calc.rawWeight.toFixed(2)}% → ${calc.adjustedWeight.toFixed(2)}% (CRITICAL ADR-adjusted)\n`;
        output += `   📋 Evidence:\n`;
        calc.evidence.forEach(evidence => {
          output += `      • ${evidence}\n`;
        });
        output += '\n';
      });
    });
    
    return output;
  }
}
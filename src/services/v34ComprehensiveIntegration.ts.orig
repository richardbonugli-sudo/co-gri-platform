export interface V34AssessmentResult {
  ticker: string;
  companyName: string;
  cogriScore: number;
  riskLevel: 'Low' | 'Medium' | 'High' | 'Critical';
  geographicExposures: GeographicExposure[];
  channelBreakdowns: ChannelBreakdown[];
  detailedCalculations: ChannelCalculationBreakdown[];
  fallbackAnalysis: {
    ssfCoverage: number;
    rfCoverage: number;
    gfCoverage: number;
    totalDataPoints: number;
    confidenceLevel: number;
  };
  dataExpansionIntegration: {
    companiesInSystem: number;
    dataQualityScore: number;
    lastUpdated: string;
    enhancedCoverage: boolean;
  };
  methodology: {
    version: '3.4';
    channels: string[];
    fallbackLogic: string;
    calculationTransparency: boolean;
  };
}

// Legacy interface for backward compatibility
export interface CompanyGeographicData {
  company: string;
  ticker: string;
  sector: string;
  segments: Array<{
    country: string;
    revenuePercentage?: number;
    exposureComponents?: {
      revenue?: number;
      operations?: number;
      supply?: number;
      assets?: number;
      market?: number;
    };
  }>;
  channelBreakdown?: Record<string, {
    revenue?: { weight: number; status: string; fallbackType?: string; source?: string };
    operations?: { weight: number; status: string; fallbackType?: string; source?: string };
    supply?: { weight: number; status: string; fallbackType?: string; source?: string };
    assets?: { weight: number; status: string; fallbackType?: string; source?: string };
    blended: number;
    politicalAlignment?: {
      alignmentFactor: number;
      relationship: string;
      source: string;
    };
  }>;
  sectorMultiplier?: number;
  hasVerifiedData?: boolean;
  dataSource?: string;
  homeCountry?: string;
  hasDetailedComponents?: boolean;
  sectorClassificationConfidence?: number;
  sectorClassificationSources?: string[];
  adrResolution?: {
    isADR: boolean;
    confidence: 'high' | 'medium' | 'low';
    source: string;
  };
}

// Enhanced ADR-aware company resolution
interface EnhancedCompanyInfo {
  ticker: string;
  name: string;
  exchange: string;
  country: string;
  sector: string;
  isADR: boolean;
  adrHomeCountry?: string;
  adrConfidence?: 'high' | 'medium' | 'low';
  adrSource?: string;
}

// ADR Information Interface
interface ADRInfo {
  isADR: boolean;
  homeCountry: string;
  confidence: 'high' | 'medium' | 'low';
  source: string;
  sector: string;
}

// Legacy function for backward compatibility with enhanced ADR support
export async function getCompanyGeographicExposure(
  ticker: string,
  param2?: any,
  param3?: any,
  param4?: any
): Promise<CompanyGeographicData> {
  // 🚨 CRITICAL ENTRY POINT LOGGING
  console.log(`🚨 [ENTRY POINT] getCompanyGeographicExposure called for: ${ticker}`);
  console.log(`🚨 [ENTRY POINT] Starting v3.4 assessment pipeline...`);
  console.log(`🚨 [ENTRY POINT] Parameters:`, { ticker, param2, param3, param4 });
  console.log(`🚨 [ENTRY POINT] Timestamp: ${new Date().toISOString()}`);
  
  console.log(`[v3.4 CRITICAL FIX] ===== STARTING ASSESSMENT FOR ${ticker} =====`);
  
  // Step 1: Enhanced company resolution with ADR detection
  const enhancedCompanyInfo = await resolveEnhancedCompanyInfo(ticker);
  
  // 🚨 COMPANY INFO LOGGING
  console.log(`🚨 [COMPANY INFO] Enhanced company resolution complete:`);
  console.log(`🚨 [COMPANY INFO] Name: ${enhancedCompanyInfo.name}`);
  console.log(`🚨 [COMPANY INFO] Country: ${enhancedCompanyInfo.country}`);
  console.log(`🚨 [COMPANY INFO] Sector: ${enhancedCompanyInfo.sector}`);
  console.log(`🚨 [COMPANY INFO] Is ADR: ${enhancedCompanyInfo.isADR}`);
  console.log(`🚨 [COMPANY INFO] ADR Home Country: ${enhancedCompanyInfo.adrHomeCountry}`);
  console.log(`🚨 [COMPANY INFO] ADR Source: ${enhancedCompanyInfo.adrSource}`);
  console.log(`🚨 [COMPANY INFO] Full Info:`, enhancedCompanyInfo);
  
  console.log(`[v3.4 CRITICAL FIX] Company Resolution Complete:`);
  console.log(`  - Name: ${enhancedCompanyInfo.name}`);
  console.log(`  - Country: ${enhancedCompanyInfo.country}`);
  console.log(`  - ADR Home Country: ${enhancedCompanyInfo.adrHomeCountry}`);
  console.log(`  - Sector: ${enhancedCompanyInfo.sector}`);
  console.log(`  - Is ADR: ${enhancedCompanyInfo.isADR}`);
  console.log(`  - ADR Source: ${enhancedCompanyInfo.adrSource}`);
  
  // Step 2: Use the new v3.4 assessment service with ADR-aware logic
  console.log(`🚨 [PRE-ASSESSMENT] About to call V34ComprehensiveIntegrationService.assessCompany`);
  console.log(`🚨 [PRE-ASSESSMENT] Company Info being passed:`, enhancedCompanyInfo);
  
  const assessment = await V34ComprehensiveIntegrationService.assessCompany(
    ticker, 
    enhancedCompanyInfo
  );
  
  // 🚨 ASSESSMENT RESULTS LOGGING
  console.log(`🚨 [POST-ASSESSMENT] Assessment completed successfully`);
  console.log(`🚨 [POST-ASSESSMENT] Geographic exposures count: ${assessment.geographicExposures.length}`);
  console.log(`🚨 [POST-ASSESSMENT] Top 5 exposures:`, assessment.geographicExposures.slice(0, 5).map(e => ({
    country: e.country,
    percentage: (e.exposurePercentage * 100).toFixed(2) + '%'
  })));
  console.log(`🚨 [POST-ASSESSMENT] Channel breakdowns count: ${assessment.channelBreakdowns.length}`);
  
  // Step 3: Convert to legacy format with proper ADR handling
  console.log(`🚨 [CONVERSION] Converting to legacy format...`);
  console.log(`🚨 [CONVERSION] Sample exposure before conversion:`, assessment.geographicExposures[0]);
  
  const segments = assessment.geographicExposures.map(exposure => ({
    country: exposure.country,
    revenuePercentage: exposure.exposurePercentage * 100,
    exposureComponents: exposure.channels ? {
      revenue: exposure.channels.revenue,
      operations: exposure.channels.financial, // Map financial to operations for legacy compatibility
      supply: exposure.channels.supply,
      assets: exposure.channels.assets,
      market: 0 // Market channel removed in v3.4
    } : undefined
  }));

  console.log(`🚨 [CONVERSION] Sample segment after conversion:`, segments[0]);
  console.log(`🚨 [CONVERSION] Total segments created: ${segments.length}`);

  // Step 4: Build channel breakdown for legacy compatibility with political alignment
  console.log(`🚨 [CHANNEL BREAKDOWN] Building channel breakdown...`);
  const channelBreakdown: Record<string, any> = {};
  
  assessment.channelBreakdowns.forEach(breakdown => {
    if (!channelBreakdown[breakdown.country]) {
      // Calculate political alignment for each country using actual home country
      const alignment = calculatePoliticalAlignment(enhancedCompanyInfo.adrHomeCountry || enhancedCompanyInfo.country, breakdown.country);
      
      channelBreakdown[breakdown.country] = {
        blended: 0,
        politicalAlignment: {
          alignmentFactor: alignment.alignmentFactor,
          relationship: alignment.relationship,
          source: alignment.source
        }
      };
    }
    
    const channelKey = breakdown.channel.includes('Revenue') ? 'revenue' :
                      breakdown.channel.includes('Supply') ? 'supply' :
                      breakdown.channel.includes('Asset') ? 'assets' :
                      breakdown.channel.includes('Financial') ? 'operations' : 'revenue';
    
    channelBreakdown[breakdown.country][channelKey] = {
      weight: breakdown.adjustedWeight,
      status: 'fallback',
      fallbackType: breakdown.fallbackType,
      source: breakdown.dataSources.join(', ')
    };
    
    // Calculate blended weight using v3.4 coefficients
    const weights = channelBreakdown[breakdown.country];
    const revenue = weights.revenue?.weight || 0;
    const supply = weights.supply?.weight || 0;
    const assets = weights.assets?.weight || 0;
    const operations = weights.operations?.weight || 0;
    
    channelBreakdown[breakdown.country].blended = 
      (revenue * 0.4) + (supply * 0.35) + (assets * 0.15) + (operations * 0.1);
  });

  console.log(`🚨 [CHANNEL BREAKDOWN] Channel breakdown created for ${Object.keys(channelBreakdown).length} countries`);
  console.log(`🚨 [CHANNEL BREAKDOWN] Sample breakdown:`, Object.keys(channelBreakdown)[0], channelBreakdown[Object.keys(channelBreakdown)[0]]);

  console.log(`[v3.4 CRITICAL FIX] Assessment completed for ${enhancedCompanyInfo.name}`);
  console.log(`[v3.4 CRITICAL FIX] Channel breakdown countries: ${Object.keys(channelBreakdown).join(', ')}`);

  // 🚨 FINAL RETURN PREPARATION
  const finalResult = {
    company: enhancedCompanyInfo.name,
    ticker: enhancedCompanyInfo.ticker,
    sector: enhancedCompanyInfo.sector,
    segments,
    channelBreakdown,
    sectorMultiplier: 1.0,
    hasVerifiedData: true,
    dataSource: 'v3.4 Enhanced Multi-Channel Assessment with CRITICAL ADR FIXES + Full Database Integration',
    homeCountry: enhancedCompanyInfo.adrHomeCountry || enhancedCompanyInfo.country, // FIXED: Use ADR home country
    hasDetailedComponents: true,
    sectorClassificationConfidence: 0.9,
    sectorClassificationSources: ['v3.4 Enhanced Assessment with Full Database'],
    adrResolution: enhancedCompanyInfo.isADR ? {
      isADR: true,
      confidence: enhancedCompanyInfo.adrConfidence || 'high',
      source: enhancedCompanyInfo.adrSource || 'v3.4 ADR Database'
    } : {
      isADR: false,
      confidence: 'high',
      source: 'v3.4 Analysis'
    }
  };

  // 🚨 FINAL RETURN LOGGING
  console.log(`🚨 [FINAL RETURN] Preparing to return data to UI...`);
  console.log(`🚨 [FINAL RETURN] Company: ${finalResult.company}`);
  console.log(`🚨 [FINAL RETURN] Home Country: ${finalResult.homeCountry}`);
  console.log(`🚨 [FINAL RETURN] Is ADR: ${finalResult.adrResolution?.isADR}`);
  console.log(`🚨 [FINAL RETURN] Total segments: ${finalResult.segments.length}`);
  console.log(`🚨 [FINAL RETURN] Top 3 segments being returned:`, finalResult.segments.slice(0, 3).map(s => ({
    country: s.country,
    percentage: s.revenuePercentage?.toFixed(2) + '%'
  })));
  console.log(`🚨 [FINAL RETURN] Sample channel breakdown:`, Object.keys(finalResult.channelBreakdown || {})[0], finalResult.channelBreakdown?.[Object.keys(finalResult.channelBreakdown || {})[0]]);
  console.log(`🚨 [FINAL RETURN] Complete result object keys:`, Object.keys(finalResult));
  
  return finalResult;
}

/**
 * Enhanced company resolution with comprehensive ADR detection and validation
 * NOW USES THE FULL DATA EXPANSION SERVICE INSTEAD OF FALLBACK DATABASE
 */
async function resolveEnhancedCompanyInfo(ticker: string): Promise<EnhancedCompanyInfo> {
  console.log(`[v3.4 CRITICAL FIX] ===== RESOLVING COMPANY INFO FOR ${ticker} =====`);
  
  // Step 1: Check data expansion service first for comprehensive company data
  console.log(`🚨 [DATA EXPANSION] Checking full database for ${ticker}...`);
  const expansionData = await dataExpansionService.getCompanyData(ticker);
  
  let companyName = `${ticker} Corporation`;
  let sector = 'Technology';
  let apiCountry = 'United States';
  const exchange = 'NASDAQ';
  
  if (expansionData) {
    console.log(`🚨 [DATA EXPANSION] Found company in full database!`);
    console.log(`🚨 [DATA EXPANSION] Name: ${expansionData.companyName}`);
    console.log(`🚨 [DATA EXPANSION] Home Country: ${expansionData.homeCountry}`);
    console.log(`🚨 [DATA EXPANSION] Sector: ${expansionData.sector}`);
    console.log(`🚨 [DATA EXPANSION] Quality Score: ${expansionData.qualityScore}`);
    
    companyName = expansionData.companyName;
    sector = expansionData.sector;
    apiCountry = expansionData.homeCountry;
  } else {
    console.log(`🚨 [DATA EXPANSION] Company not found in full database, using fallback data`);
  }
  
  console.log(`[v3.4 CRITICAL FIX] Company database lookup:`);
  console.log(`  - Name: ${companyName}`);
  console.log(`  - Country: ${apiCountry}`);
  console.log(`  - Sector: ${sector}`);
  console.log(`  - Exchange: ${exchange}`);
  
  // Step 2: Enhanced ADR resolution with multiple validation layers
  const adrResolution = resolveADRCountry(ticker, companyName, apiCountry, exchange);
  
  console.log(`[v3.4 CRITICAL FIX] ADR resolution result:`);
  console.log(`  - Country: ${adrResolution.country}`);
  console.log(`  - Is ADR: ${adrResolution.isADR}`);
  console.log(`  - Confidence: ${adrResolution.confidence}`);
  console.log(`  - Source: ${adrResolution.source}`);
  
  // Step 3: Determine final country and ADR status
  let finalCountry = adrResolution.country;
  let isADR = adrResolution.isADR;
  
  // Step 4: Enhanced validation for known ADRs
  if (isKnownADR(ticker)) {
    const knownADRCountry = getADRCountry(ticker);
    if (knownADRCountry && knownADRCountry !== finalCountry) {
      console.log(`[v3.4 CRITICAL FIX] *** OVERRIDE: Known ADR ${ticker} -> ${knownADRCountry} (was ${finalCountry}) ***`);
      finalCountry = knownADRCountry;
      isADR = true;
      adrResolution.confidence = 'high';
      adrResolution.source = 'Known ADR Database (v3.4 Enhanced)';
    }
  }
  
  // Step 5: Special handling for major ADRs with name corrections
  const enhancedADRInfo = getEnhancedADRInfo(ticker, companyName);
  if (enhancedADRInfo) {
    console.log(`[v3.4 CRITICAL FIX] *** ENHANCED ADR INFO APPLIED ***`);
    console.log(`  - Original Name: ${companyName}`);
    console.log(`  - Enhanced Name: ${enhancedADRInfo.correctedName}`);
    console.log(`  - Original Country: ${finalCountry}`);
    console.log(`  - Enhanced Country: ${enhancedADRInfo.homeCountry}`);
    
    companyName = enhancedADRInfo.correctedName;
    finalCountry = enhancedADRInfo.homeCountry;
    sector = enhancedADRInfo.sector || sector;
    isADR = true;
  }
  
  console.log(`[v3.4 CRITICAL FIX] ===== FINAL RESOLUTION =====`);
  console.log(`  - Company: ${companyName}`);
  console.log(`  - Country: ${finalCountry}`);
  console.log(`  - Sector: ${sector}`);
  console.log(`  - Is ADR: ${isADR}`);
  console.log(`  - Confidence: ${adrResolution.confidence}`);
  console.log(`  - Source: ${adrResolution.source}`);
  
  // CRITICAL FIX: Ensure adrHomeCountry is always set for ADRs
  const result = {
    ticker: ticker.toUpperCase(),
    name: companyName,
    exchange,
    country: finalCountry,
    sector,
    isADR,
    adrHomeCountry: isADR ? finalCountry : undefined,
    adrConfidence: adrResolution.confidence,
    adrSource: adrResolution.source
  };
  
  // 🚨 CRITICAL LOGGING: Verify adrHomeCountry is set
  console.log(`🚨 [CRITICAL ADR FIELD CHECK] Final company info for ${ticker}:`);
  console.log(`🚨 [CRITICAL ADR FIELD CHECK] - isADR: ${result.isADR}`);
  console.log(`🚨 [CRITICAL ADR FIELD CHECK] - country: ${result.country}`);
  console.log(`🚨 [CRITICAL ADR FIELD CHECK] - adrHomeCountry: ${result.adrHomeCountry}`);
  console.log(`🚨 [CRITICAL ADR FIELD CHECK] - Will post-processing trigger? ${result.isADR && result.adrHomeCountry ? 'YES' : 'NO'}`);
  
  return result;
}


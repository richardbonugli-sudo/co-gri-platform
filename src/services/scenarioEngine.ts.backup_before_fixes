/**
 * ENHANCEMENT 2: Determine evidence level based on data source and quality
 */
function getEvidenceLevel(
  hasDirectData: boolean,
  isFallback: boolean,
  isKnownZero: boolean,
  fallbackType?: 'SSF' | 'RF' | 'GF',
  confidenceScore?: number
): 'A+' | 'A' | 'B' | 'C' | 'D' | 'None' {
  if (isKnownZero) {
    return 'A+'; // Known zeros have highest certainty
  }
  
  if (hasDirectData && !isFallback) {
    // Direct bilateral data with sector validation
    if (confidenceScore && confidenceScore >= 95) return 'A+';
    if (confidenceScore && confidenceScore >= 90) return 'A';
    return 'B';
  }
  
  if (isFallback) {
    if (fallbackType === 'SSF') return 'C'; // Sector Intelligence (60-69%)
    if (fallbackType === 'RF') return 'D'; // Estimate (50-59%)
    if (fallbackType === 'GF') return 'D'; // Estimate (50-59%)
  }
  
  return 'None';
}

/**
 * ENHANCEMENT 2 & 3 & PHASE 2: Create channel data source information
 */
function createChannelDataSource(
  channel: 'trade' | 'supplyChain' | 'financial',
  rawValue: number,
  displayValue: number,
  hasDirectData: boolean,
  isFallback: boolean,
  fallbackType?: 'SSF' | 'RF' | 'GF',
  knownZeroReason?: string,
  sectorSpecificMethod?: string
): ChannelDataSource {
  let dataSource: ChannelDataSource['dataSource'];
  let description: string;
  let confidenceScore: number;
  const isKnownZero = knownZeroReason !== undefined;
  
  if (isKnownZero) {
    // ENHANCEMENT 3: Known Zero path
    dataSource = 'Known Zero';
    confidenceScore = 100;
    description = `Known structural zero: ${knownZeroReason}`;
  } else if (hasDirectData && !isFallback) {
    // PHASE 1 & 2 DATA INTEGRATION: Direct data path with enhanced confidence
    dataSource = 'Direct Data';
    
    if (channel === 'trade') {
      confidenceScore = 92; // UN COMTRADE confidence
      description = `Direct Data - UN COMTRADE, 92% confidence`;
    } else if (channel === 'supplyChain') {
      confidenceScore = 95; // OECD ICIO confidence
      description = `Direct Data - OECD ICIO, 95% confidence`;
    } else {
      confidenceScore = 98; // Unified Financial Linkage (multi-source)
      description = `Direct Data - CPIS + FDI + BIS, 98% confidence`;
    }
  } else if (isFallback) {
    // PHASE 2: Enhanced fallback path with sector-specific methods
    dataSource = 'Fallback Method';
    
    if (sectorSpecificMethod) {
      // Sector-specific fallback (higher confidence)
      confidenceScore = 65;
      description = sectorSpecificMethod;
    } else if (channel === 'supplyChain') {
      if (fallbackType === 'RF' || fallbackType === 'GF') {
        confidenceScore = 55;
        description = `Estimated supply chain dependency based on trade patterns and regional proximity`;
      } else {
        confidenceScore = 60;
        description = `Estimated supply chain dependency using trade-based proxy (30% of trade intensity)`;
      }
    } else if (channel === 'financial') {
      if (fallbackType === 'RF' || fallbackType === 'GF') {
        confidenceScore = 50;
        description = `Estimated financial linkage based on trade patterns and regional proximity`;
      } else {
        confidenceScore = 55;
        description = `Estimated financial linkage using trade-based proxy (20% of trade intensity)`;
      }
    } else if (fallbackType === 'SSF') {
      confidenceScore = 65;
      description = `Segment-Specific Fallback: Regional patterns with limited data`;
    } else if (fallbackType === 'RF') {
      confidenceScore = 55;
      description = `Regional Fallback: Geographic proximity-based estimates`;
    } else if (fallbackType === 'GF') {
      confidenceScore = 50;
      description = `Global Fallback: Minimal exposure estimates`;
    } else {
      confidenceScore = 60;
      description = `Sector-based estimate using industry patterns`;
    }
  } else if (rawValue === 0) {
    // No data path
    dataSource = 'No Data';
    confidenceScore = 0;
    description = `No ${channel} data available for this country pair`;
  } else {
    // Sector estimate path
    dataSource = 'Sector Estimate';
    confidenceScore = 70;
    description = `Sector-validated estimate based on industry patterns`;
  }
  
  const evidenceLevel = getEvidenceLevel(hasDirectData, isFallback, isKnownZero, fallbackType, confidenceScore);
  
  return {
    channel,
    dataSource,
    evidenceLevel,
    confidenceScore,
    fallbackType: fallbackType || 'None',
    description,
    rawValue,
    displayValue,
    isRealData: hasDirectData && !isFallback && !isKnownZero,
    knownZeroReason,
    sectorSpecificMethod
  };
}

function getSeverityMultiplier(severity: 'low' | 'medium' | 'high'): number {
  return SEVERITY_SCALARS[severity];
}

function getEventCSIImpact(eventType: string, severity: 'low' | 'medium' | 'high'): number {
  const baseImpact = EVENT_BASE_SHOCKS[eventType] || EVENT_BASE_SHOCKS['Custom Event'];
  const multiplier = getSeverityMultiplier(severity);
  return baseImpact * multiplier;
}

function getTopTradePartners(targetCountry: string, N: number = 15): Array<{country: string, rank: number, intensity: number}> {
  const tradeData = BILATERAL_TRADE_INTENSITY[targetCountry];
  if (!tradeData) return [];
  
  return Object.entries(tradeData)
    .map(([country, intensity]) => ({ country, intensity, rank: 0 }))
    .sort((a, b) => b.intensity - a.intensity)
    .slice(0, N)
    .map((item, index) => ({ ...item, rank: index + 1 }));
}

function areInSameRegion(country1: string, country2: string): boolean {
  for (const region of Object.values(GEOGRAPHIC_REGIONS)) {
    if (region.includes(country1) && region.includes(country2)) {
      return true;
    }
  }
  return false;
}

function calculateFallbackExposure(spilloverCountry: string, targetCountry: string) {
  const geographicProximity = areInSameRegion(spilloverCountry, targetCountry);
  const spilloverCSI = getCountryShockIndex(spilloverCountry);
  const targetCSI = getCountryShockIndex(targetCountry);
  const csiDifference = Math.abs(spilloverCSI - targetCSI);
  const csiSimilarity = 1 - (csiDifference / 100);
  
  let estimatedExposure = 0;
  const qualificationCriteria: string[] = [];
  
  if (geographicProximity) {
    estimatedExposure = 0.025 * csiSimilarity;
    qualificationCriteria.push('Same geographic region');
    if (csiSimilarity >= 0.8) {
      qualificationCriteria.push(`Similar CSI (Δ${csiDifference.toFixed(0)} points)`);
    }
  } else {
    estimatedExposure = 0.008 * csiSimilarity;
  }
  
  const hasMaterialExposure = geographicProximity && csiDifference <= 25;
  
  const detailedBreakdown = [
    `FALLBACK METHOD`,
    `Geographic: ${geographicProximity ? 'Same region' : 'Different region'}`,
    `CSI: ${spilloverCSI.toFixed(0)} vs ${targetCSI.toFixed(0)} (Δ${csiDifference.toFixed(0)})`,
    `Similarity: ${(csiSimilarity * 100).toFixed(0)}%`,
    `Estimated Exposure: ${(estimatedExposure * 100).toFixed(2)}%`,
    `Qualified: ${hasMaterialExposure ? 'Yes' : 'No'}`
  ].join(' | ');
  
  return {
    hasMaterialExposure,
    tradeRank: 999,
    tradeIntensity: estimatedExposure,
    supplyChainScore: 0,
    financialLinkage: 0,
    geographicProximity,
    materialityScore: estimatedExposure,
    qualificationCriteria,
    detailedBreakdown,
    supplyChainIsFallback: false,
    supplyChainFallbackType: undefined,
    supplyChainKnownZeroReason: undefined,
    supplyChainSectorMethod: undefined,
    financialIsFallback: false,
    financialFallbackType: undefined,
    financialKnownZeroReason: undefined,
    financialSectorMethod: undefined,
    isFallback: true,
    fallbackType: geographicProximity ? 'RF' as const : 'GF' as const,
    hasDirectEvidence: false
  };
}


/**
 * PHASE 1 + PHASE 2: Enhanced supply chain fallback
 * Priority: 1. Known Zero 2. OECD ICIO 3. Sector-specific 4. Trade-proxy 5. Regional
 */
function estimateSupplyChainFallback(
  sourceCountry: string,
  targetCountry: string,
  tradeIntensity: number
): { 
  value: number; 
  method: 'trade-proxy' | 'sector-pattern' | 'regional' | 'known-zero' | 'oecd-icio'; 
  confidence: number; 
  knownZeroReason?: string;
  sectorSpecificMethod?: string;
} {
  // ENHANCEMENT 3: Check for Known Zero FIRST
  if (isEmbargoed(sourceCountry, targetCountry)) {
    return {
      value: 0,
      method: 'known-zero',
      confidence: 100,
      knownZeroReason: `Embargo between ${sourceCountry} and ${targetCountry}`
    };
  }
  
  if (isIsolated(sourceCountry) || isIsolated(targetCountry)) {
    return {
      value: 0,
      method: 'known-zero',
      confidence: 100,
      knownZeroReason: `${isIsolated(sourceCountry) ? sourceCountry : targetCountry} is economically isolated`
    };
  }
  
  // PHASE 1 DATA INTEGRATION: Check OECD ICIO data SECOND (before fallbacks)
  const oecdData = getOECDSupplyChainIntensity(sourceCountry, targetCountry);
  if (oecdData !== null && oecdData > 0) {
    return {
      value: oecdData,
      method: 'oecd-icio',
      confidence: 95,
      sectorSpecificMethod: `OECD ICIO supply chain data (2018 edition)`
    };
  }
  
  // PHASE 2: Try sector-specific fallback third
  const sector = detectSector(sourceCountry, targetCountry);
  const evidenceCountries = new Set<string>();
  const knownZeroCountries = new Set<string>();
  
  // Check if we should use sector-specific fallback
  if (tradeIntensity < 0.01) {
    const sectorFallback = supplyChainFallbackService.getSupplyChainFallback(
      sector,
      sourceCountry,
      evidenceCountries,
      knownZeroCountries,
      1.0 // Full unknown portion for single country pair
    );
    
    if (sectorFallback[targetCountry]) {
      const fallbackData = sectorFallback[targetCountry];
      return {
        value: Math.max(0.01, fallbackData.weight),
        method: 'sector-pattern',
        confidence: 65,
        sectorSpecificMethod: `${sector} sector supply chain pattern: ${fallbackData.source}`
      };
    }
  }
  
  // Method 4: Trade-based proxy
  if (tradeIntensity > 0.01) {
    // Supply chain dependency is typically ~30% of trade intensity
    const estimate = Math.max(0.01, tradeIntensity * 0.30); // Ensure minimum 0.01
    return {
      value: estimate,
      method: 'trade-proxy',
      confidence: 65
    };
  }
  
  // Method 5: Regional proximity
  const geographicProximity = areInSameRegion(sourceCountry, targetCountry);
  if (geographicProximity) {
    // Regional neighbors have higher supply chain integration
    const sourceCSI = getCountryShockIndex(sourceCountry);
    const targetCSI = getCountryShockIndex(targetCountry);
    const csiSimilarity = 1 - (Math.abs(sourceCSI - targetCSI) / 100);
    const estimate = Math.max(0.01, 0.025 * csiSimilarity); // Ensure minimum 0.01
    return {
      value: estimate,
      method: 'regional',
      confidence: 50
    };
  }
  
  // Method 6: Minimal estimate for global pairs (non-zero unless known zero)
  return {
    value: 0.01, // Changed from 0.005 to 0.01 minimum
    method: 'regional',
    confidence: 40
  };
}

